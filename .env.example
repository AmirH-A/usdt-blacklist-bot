# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token

# Webhook URL (for production, e.g., https://your-domain.com)
# Leave empty for local development (uses polling mode)
WEBHOOK_URL=

# Webhook secret for verifying Telegram requests
WEBHOOK_SECRET=your_webhook_secret

# TronGrid API Key (optional but recommended for higher rate limits)
# Get one at: https://www.trongrid.io/
TRONGRID_API_KEY=

# Etherscan API Key (required for ETH monitoring)
# Get one at: https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Chain toggles (both enabled by default)
ENABLE_TRON=true
ENABLE_ETH=true

# SQLite database path
DB_PATH=blacklist_tracker.db
